# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — never expose to the client, never commit real values
SUPABASE_SERVICE_ROLE_KEY=

# Stripe (test mode while building)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Map (MapLibre + a tile provider, e.g. MapTiler/Mapbox)
NEXT_PUBLIC_MAP_TILES_API_KEY=
